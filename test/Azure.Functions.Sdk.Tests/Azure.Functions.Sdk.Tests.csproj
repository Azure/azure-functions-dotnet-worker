<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net10.0</TargetFrameworks>
    <TargetFrameworks Condition="'$(OS)' == 'Windows_NT'">$(TargetFrameworks);net472</TargetFrameworks>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <ResolverProject>../Azure.Functions.Sdk.Resolver/Azure.Functions.Sdk.Resolver.csproj</ResolverProject>
  </PropertyGroup>

  <ItemGroup>
    <Using Include="AwesomeAssertions" />
    <Using Include="Moq" />
    <Using Include="Xunit" />
    <!-- Not part of net472 usings for some reason. -->
    <Using Include="System.Net.Http" Condition="'$(TargetFramework)' == 'net472'"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="$(SrcRoot)Azure.Functions.Sdk/Azure.Functions.Sdk.csproj" />
    <ProjectReference Include="$(ResolverProject)" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <!--
    Sample extension assemblies scanned by FunctionsAssemblyScannerTests. They are built but not
    referenced (ReferenceOutputAssembly=false). Each extension references the real WebJobs /
    Worker.Extensions.Abstractions packages that define the marker attributes. OutputItemType
    captures each sample's own primary assembly (not its package dependencies) into
    @(SampleExtensionOutput) as part of ResolveProjectReferences.
  -->
  <ItemGroup>
    <SampleExtensionProject Include="$(TestRoot)Resources/AssemblyScanner/**/*.csproj" />
    <ProjectReference Include="@(SampleExtensionProject)"
                      ReferenceOutputAssembly="false"
                      OutputItemType="SampleExtensionOutput" />
  </ItemGroup>

  <!--
    Rather than copying the sample assemblies next to the test binary, generate a source file that
    records the absolute path of each sample's build output and scan them in place. Each extension
    is read from its own output directory, where only that extension's assembly lives - the
    attribute-defining packages (Microsoft.Azure.WebJobs.Host, Worker.Extensions.Abstractions) are
    absent, so the scanner must match the marker attributes as external TypeReferences without
    resolving the defining assembly, mirroring how Microsoft.Azure.WebJobs.Host is absent from the
    production payload. Scanning in place also sidesteps the net472 shadow-copy problem that a
    deployed content folder had (Assembly.Location points at the shadow cache, not the payload).
    Runs after ResolveProjectReferences (which populates @(SampleExtensionOutput)) and before
    CoreCompile so the generated file is part of the compilation.
  -->
  <Target Name="_GenerateSampleExtensionPaths"
          DependsOnTargets="ResolveProjectReferences"
          BeforeTargets="CoreCompile">
    <PropertyGroup>
      <_SampleExtensionPathsFile>$(IntermediateOutputPath)SampleExtensions.g.cs</_SampleExtensionPathsFile>
    </PropertyGroup>
    <ItemGroup>
      <_SampleExtensionEntry Include="@(SampleExtensionOutput)">
        <Line>            ["%(Filename)"] = @"%(FullPath)",</Line>
      </_SampleExtensionEntry>
      <_SampleExtensionsLine Include="// &lt;auto-generated/&gt;" />
      <_SampleExtensionsLine Include="namespace Azure.Functions.Sdk.Tests%3B" />
      <_SampleExtensionsLine Include="internal static class SampleExtensions" />
      <_SampleExtensionsLine Include="{" />
      <_SampleExtensionsLine Include="    public static readonly System.Collections.Generic.IReadOnlyDictionary&lt;string, string&gt; Paths =" />
      <_SampleExtensionsLine Include="        new System.Collections.Generic.Dictionary&lt;string, string&gt;(System.StringComparer.OrdinalIgnoreCase)" />
      <_SampleExtensionsLine Include="        {" />
      <_SampleExtensionsLine Include="@(_SampleExtensionEntry->'%(Line)')" />
      <_SampleExtensionsLine Include="        }%3B" />
      <_SampleExtensionsLine Include="}" />
    </ItemGroup>

    <WriteLinesToFile File="$(_SampleExtensionPathsFile)"
                      Lines="@(_SampleExtensionsLine)"
                      Overwrite="true"
                      WriteOnlyWhenDifferent="true" />

    <ItemGroup>
      <Compile Include="$(_SampleExtensionPathsFile)" />
      <FileWrites Include="$(_SampleExtensionPathsFile)" />
    </ItemGroup>
  </Target>

  <ItemGroup>
    <PackageReference Include="AwesomeAssertions" Version="9.3.0" />
    <PackageReference Include="AwesomeAssertions.Analyzers" Version="9.0.8" PrivateAssets="all" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.5.1" />
    <PackageReference Include="Moq" Version="4.18.4" />
    <PackageReference Include="MSBuild.ProjectCreation" Version="16.1.0" />
    <PackageReference Include="TestableIO.System.IO.Abstractions.TestingHelpers" Version="22.0.15" />
    <PackageReference Include="xunit" Version="2.9.0" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.5" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <!-- Microsoft.Build assemblies are loaded from the current dotnet SDK. This is required to integration test our SDK. -->
    <PackageReference Include="Microsoft.Build" Version="17.14.28" ExcludeAssets="runtime" />
    <PackageReference Include="Microsoft.Build.Framework" Version="17.14.28" ExcludeAssets="runtime" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.ResxSourceGenerator" Version="5.0.0-1.25277.114" PrivateAssets="all" />
  </ItemGroup>

</Project>
