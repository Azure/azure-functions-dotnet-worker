<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net10.0</TargetFrameworks>
    <TargetFrameworks Condition="'$(OS)' == 'Windows_NT'">$(TargetFrameworks);net472</TargetFrameworks>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <ResolverProject>../Azure.Functions.Sdk.Resolver/Azure.Functions.Sdk.Resolver.csproj</ResolverProject>
  </PropertyGroup>

  <ItemGroup>
    <Using Include="AwesomeAssertions" />
    <Using Include="Moq" />
    <Using Include="Xunit" />
    <!-- Not part of net472 usings for some reason. -->
    <Using Include="System.Net.Http" Condition="'$(TargetFramework)' == 'net472'"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="$(SrcRoot)Azure.Functions.Sdk/Azure.Functions.Sdk.csproj" />
    <ProjectReference Include="$(ResolverProject)" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <!--
    Sample extension assemblies scanned by FunctionsAssemblyScannerTests. They are built but not
    referenced (ReferenceOutputAssembly=false). Each extension references the real WebJobs /
    Worker.Extensions.Abstractions packages that define the marker attributes, but only the
    extension's own primary assembly is copied next to the tests (see _IncludeSampleExtensions) -
    the attribute-defining assemblies are therefore absent from the scanned payload, so the
    attributes surface as external TypeReferences that the scanner must match without resolving
    the defining assembly, mirroring how Microsoft.Azure.WebJobs.Host is absent from the payload.
  -->
  <ItemGroup>
    <SampleExtensionProject Include="$(TestRoot)Resources\AssemblyScanner\**\*.csproj" />
    <ProjectReference Include="@(SampleExtensionProject)" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <!--
    Register the sample extension outputs as copy-to-output content under an "extensions" folder.
    This mirrors the resolver project's approach so the files are deployed (and shadow-copied by
    the net472 test host) next to the test assembly, where the tests resolve them via
    Assembly.Location.
  -->
  <Target Name="_IncludeSampleExtensions"
          AfterTargets="ResolveProjectReferences"
          BeforeTargets="GetCopyToOutputDirectoryItems">
    <MSBuild Projects="@(SampleExtensionProject)" Targets="GetTargetPath" RemoveProperties="TargetFramework">
      <Output TaskParameter="TargetOutputs" ItemName="_SampleExtensionOutput" />
    </MSBuild>
    <ItemGroup>
      <AllItemsFullPathWithTargetPath Include="@(_SampleExtensionOutput)"
          CopyToOutputDirectory="PreserveNewest"
          TargetPath="extensions/%(_SampleExtensionOutput.Filename)%(_SampleExtensionOutput.Extension)" />
    </ItemGroup>
  </Target>

  <ItemGroup>
    <PackageReference Include="AwesomeAssertions" Version="9.3.0" />
    <PackageReference Include="AwesomeAssertions.Analyzers" Version="9.0.8" PrivateAssets="all" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.5.1" />
    <PackageReference Include="Moq" Version="4.18.4" />
    <PackageReference Include="MSBuild.ProjectCreation" Version="16.1.0" />
    <PackageReference Include="TestableIO.System.IO.Abstractions.TestingHelpers" Version="22.0.15" />
    <PackageReference Include="xunit" Version="2.9.0" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.5" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <!-- Microsoft.Build assemblies are loaded from the current dotnet SDK. This is required to integration test our SDK. -->
    <PackageReference Include="Microsoft.Build" Version="17.14.28" ExcludeAssets="runtime" />
    <PackageReference Include="Microsoft.Build.Framework" Version="17.14.28" ExcludeAssets="runtime" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.ResxSourceGenerator" Version="5.0.0-1.25277.114" PrivateAssets="all" />
  </ItemGroup>

</Project>
